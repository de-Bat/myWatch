# Copy to .env and fill in values before running docker compose

# --- Ports ---
PORT_WEB=3000
PORT_API=3001
PORT_DB=5432

# --- API ---
JWT_SECRET=change-me-to-a-random-secret

# --- Web ---
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
AUTH_SECRET=change-me-to-a-random-secret

# --- Derived URLs (auto-computed from PORT_* above — leave commented unless overriding) ---
# These are built automatically from PORT_WEB / PORT_API by docker-compose.
# Uncomment ONLY if you need a custom value (e.g. LAN IP for device access).
# If set here, they take precedence over the port variables above.
#
# AUTH_URL=http://localhost:3000          # auto: http://localhost:${PORT_WEB}
# NEXT_PUBLIC_API_URL=http://localhost:3001  # auto: http://localhost:${PORT_API}
# INTERNAL_API_URL=http://api:3001        # auto: http://api:${PORT_API} (Docker only)

# LAN / device access — uncomment and set your machine's local IP:
# AUTH_URL=http://192.168.1.x:3000
# NEXT_PUBLIC_API_URL=http://192.168.1.x:3001

# --- Optional: Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional: Apple Sign-In ---
APPLE_ID=
APPLE_SECRET=
