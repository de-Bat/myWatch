# Copy to .env and fill in values before running docker compose

# --- Ports ---
PORT_WEB=3000
PORT_API=3001
PORT_DB=5432

# --- API ---
JWT_SECRET=change-me-to-a-random-secret

# --- Web ---
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
AUTH_SECRET=change-me-to-a-random-secret

# URL the web app is served from (used for OAuth callbacks)
AUTH_URL=http://localhost:3000

# Public API URL (baked into Next.js at build time — must match PORT_API if changed)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal Docker network URL — Next.js server-side calls use this to reach the API
# container. Do not change unless you rename the api service in docker-compose.yml.
# Not needed for manual (non-Docker) setup.
INTERNAL_API_URL=http://api:3001

# If accessing from another device (iOS/TV), set to your LAN IP:
# AUTH_URL=http://192.168.1.x:3000
# NEXT_PUBLIC_API_URL=http://192.168.1.x:3001

# --- Optional: Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional: Apple Sign-In ---
APPLE_ID=
APPLE_SECRET=
